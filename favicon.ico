<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 800" width="100%" height="100%">
  <rect width="800" height="800" fill="#000000" />

  <defs>
    <clipPath id="left-clip">
      <rect x="0" y="0" width="400" height="800" />
    </clipPath>
    <clipPath id="right-clip">
      <rect x="400" y="0" width="400" height="800" />
    </clipPath>
  </defs>

  <g font-family="Didot, 'Bodoni MT', 'Times New Roman', serif" font-size="500" fill="#FFFFFF">
    <text x="440" y="600" text-anchor="end" clip-path="url(#left-clip)">A</text>
    <text x="360" y="600" text-anchor="start" clip-path="url(#right-clip)">S</text>
  </g>

  <path d="M400,100 L400,750 Q430,550 430,425 Q430,300 400,100 Z" fill="#FFFFFF" />
</svg>
